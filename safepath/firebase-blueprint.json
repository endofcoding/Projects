{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in" }
      },
      "required": ["uid", "email"]
    },
    "SavedRoute": {
      "title": "SavedRoute",
      "description": "A route saved by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the saved route" },
        "userId": { "type": "string", "description": "UID of the user who saved the route" },
        "name": { "type": "string", "description": "Name of the route" },
        "origin": { "type": "string", "description": "Starting point address" },
        "destination": { "type": "string", "description": "Ending point address" },
        "coordinates": { "type": "array", "description": "Array of lat/lng pairs" },
        "safetyScore": { "type": "number", "description": "Overall safety score" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the route was saved" }
      },
      "required": ["id", "userId", "name", "coordinates"]
    },
    "SafetyReport": {
      "title": "SafetyReport",
      "description": "A safety report pinned on the map",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the report" },
        "userId": { "type": "string", "description": "UID of the user who created the report" },
        "type": { "type": "string", "enum": ["lighting", "construction", "crowded", "isolated", "other", "safe-haven"], "description": "Type of safety report" },
        "description": { "type": "string", "description": "Details about the report" },
        "lat": { "type": "number", "description": "Latitude" },
        "lng": { "type": "number", "description": "Longitude" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the report was created" }
      },
      "required": ["id", "userId", "type", "lat", "lng"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profile data"
    },
    "/savedRoutes/{routeId}": {
      "schema": "SavedRoute",
      "description": "Routes saved by users"
    },
    "/safetyReports/{reportId}": {
      "schema": "SafetyReport",
      "description": "Safety reports shared by users"
    }
  }
}
