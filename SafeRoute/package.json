{
  "name": "saferoute",
  "version": "1.0.0",
  "description": "SafeRoute - A secure route planning mobile app",
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "build:ios": "xcodebuild -workspace ios/SafeRoute.xcworkspace -scheme SafeRoute -configuration Release",
    "build:android:apk": "cd android && ./gradlew assembleRelease && cd ..",
    "build:android:aab": "cd android && ./gradlew bundleRelease && cd ..",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "clean": "npm install && npm start -- --reset-cache",
    "ios:pods": "cd ios && pod install && cd .."
  },
  "keywords": [
    "react-native",
    "mobile",
    "route",
    "safety"
  ],
  "author": "SafeRoute Team",
  "license": "MIT",
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@react-navigation/stack": "^7.8.6",
    "axios": "^1.3.0",
    "dotenv": "^16.0.3",
    "expo": "^55.0.5",
    "react": "^19.2.0",
    "react-dom": "19.2.0",
    "react-native": "^0.83.2",
    "react-native-gesture-handler": "^2.11.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/preset-env": "^7.21.0",
    "@babel/preset-react": "^7.18.0",
    "@babel/preset-typescript": "^7.21.0",
    "@types/react": "^19.2.10",
    "@types/react-native": "^0.71.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "babel-jest": "^29.5.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^55.0.10",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-native": "^4.0.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  }
}
